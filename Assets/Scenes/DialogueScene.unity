MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2016967437}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: "And thus, Paige sough out Pete, the only other person in the world who
      still knew how to work a guitar. (Except if you also learned to play from Paige,
      which would be a fairly easy variable to read out when determining the ending,
      but we didn\u2019t do that.) Together they toured the land, wrote classic songs
      and eventually disappeared."
  - character: 0
    words: It is said they fell in love and had children, every one of them as talented
      on the guitar as their parents were.
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: 3
