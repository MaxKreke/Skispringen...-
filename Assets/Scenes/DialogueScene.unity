MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 314026880}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 3
    words: Fuck you, I got a handle on my booze.
  - character: 0
    words: You have a long conversation with Bonzo, that would be much too serious
      to play out in a dumb game like this. By the end he seems to understand.
  - character: 3
    words: Thanks man, I never knew how much of my life had been taken over by this
      stuff. From now on I will drink responsibly.
  - character: 0
    words: You feel like a real stand-up guy. Then you leave.
  state: 0
  setsFlag: 16
  gainsStat: -1
  isEnding: -1
