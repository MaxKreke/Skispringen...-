  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 2
    words: "But it\u2019s more than just a stairway. It is a symbol of the heights
      a chosen few of us can ascend to. Heights that most mortals cannot even imagine.
      But how am I meant to reach those heights, if the others keep getting in my
      way."
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
