  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 3
    words: Alright, coming right up.
  - character: 0
    words: You have another drink. And then another. And one more. Until it is suddenly
      evening, and you can barely stand. You stagger back to le Zeppelin.
  - character: 3
    words: You sure you good to drive?
  - character: 6
    words: "What\u2019s the worst that could happen? Ain\u2019t nothing bad ever
      happened to a Zeppelin."
  - character: 3
    words: Right you are, see you later then.
  - character: 0
    words: Your bender with Bonzo has given you a knew appreciation for getting wasted.
  state: 0
  setsFlag: 4
  gainsStat: 2
  isEnding: -1
