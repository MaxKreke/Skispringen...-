  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 2016967439}
  dialogueContent:
  - character: 1
    words: Another guitarist, truly? I always thought I was the last of my kind.
  - character: 1
    words: "Perhaps he can understand me in that way that Rob and the others can\u2019t.
      I need to go see him."
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
