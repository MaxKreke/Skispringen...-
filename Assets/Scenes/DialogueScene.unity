  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 2
    words: "Probably. How hard can it be if Paige can manage it? If you\u2019re ever
      good enough or found another guitarist who knows their place, let me know.
      Then I can finally leave those amateurs behind."
  state: 0
  setsFlag: 2
  gainsStat: -1
  isEnding: -1
