  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 4
    words: If it puts you at ease.
  - character: 0
    words: He opens his eyes and rises from the ground, almost as if lifted by an
      invisible hand.
  - character: 4
    words: I know why you are here.
  - character: 4
    words: As soon as the other band members are willing to return to the studio,
      I will be there.
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
