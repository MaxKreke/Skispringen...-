--- !u!114 &915317866
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 915317864}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 1
    words: "What? No, I mean, it\u2019s an expression. I didn\u2019t actually\u2026"
  - character: 1
    words: Well, what matters is you got the guitar.
  - character: 1
    words: "I\u2019m still not over how the others treated me, but I\u2019m willing
      to try again if they can stay mature this time around."
  - character: 1
    words: "Swing by later if you want to learn some guitar playing. It\u2019s the
      only thing I can do to say thank you right now."
  state: 0
  setsFlag: 14
  gainsStat: -1
  isEnding: -1
