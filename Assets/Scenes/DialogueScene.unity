  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: You return to the stairway to find Rob, still in awe. This time, he notices
      your arrival sooner.
  - character: 2
    words: Hey, made any progress with the others?
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
