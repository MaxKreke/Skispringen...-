  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: And thus, Pete, Bonzo and the Manager all lived happily ever after in
      octopus garden, never having a shortage of brown sugar or beer. Until they
      all died at the ripe old age of somewhere around 30. Happy endings indeed.
  state: 0
