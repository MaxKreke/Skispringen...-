  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 1
    words: Who are the Yardbirds? I just meant that the woman who taught me to play
      owned a parrot. He liked to squawk when we played.
  - character: 1
    words: And now I have gone and thrown my guitar away into the ocean, just because
      I let Rob and Bonzo get a rise out of me.
  - character: 1
    words: "You don\u2019t think you can get me a new one, do you?"
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
