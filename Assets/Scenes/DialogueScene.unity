  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 137432238}
  dialogueContent:
  - character: 4
    words: "I\u2019m not really that spiritual for a bass player, I think. Most of
      us are pretty attuned to the cosmos. You know, with the bass\u2019 e-string
      being tuned to Om and all."
  - character: 4
    words: "Now why don\u2019t we meditate together? I have a feeling you\u2019re
      still a bit ruffled from the band\u2019s fight. "
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
