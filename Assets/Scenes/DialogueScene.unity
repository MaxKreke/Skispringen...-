--- !u!114 &1623237055
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1623237053}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: "As you look for Paul, you stroll through an otherworldly mountain valley,
      animals that you have never seen before (and won\u2019t ever see, because we
      didn\u2019t illustrate them) in all the colours of the rainbow, even the secret
      ones."
  - character: 0
    words: Eventually you find Paul, sitting next to a stream, meditating with his
      eyes closed.
  - character: 4
    words: Please, sit with me.
  - character: 0
    words: He seems to have noticed you approaching but does not exit his meditation.
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
