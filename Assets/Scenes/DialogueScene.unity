  next: {fileID: 0}
  dialogueContent:
  - character: 1
    words: "Great, so we can\u2019t buy a new guitar until we\u2019ve recorded a
      song."
  - character: 1
    words: "And we can\u2019t record a song without a guitar."
  - character: 1
    words: "Don\u2019t suppose you\u2019d be able to find the guitar I threw out?"
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
