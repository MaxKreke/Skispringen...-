  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: And thus, after just 5 sessions of meditation, you became enlightened
      and became a Buddha, while Paul stayed behind, walking the world as a Bodhisattva,
      alleviating the suffering of people wherever he went.
  - character: 0
    words: Or maybe you are lying in the mountains, drooling and will wake up in
      half an hour, feeling pretty stupid. Who knows, honestly.
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: 1
