  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: And thus, Rob went solo. He achieved the very heights he aspired to. And
      all he had to leave behind? Only his former bandmates and closest friends,
      his sense of modesty and his soul. Yet such things are but trifles, fame is
      eternal.
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: 0
