--- !u!114 &679207434
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 679207432}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3b5fd1cffcd1fa443a75183a67b46a41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MulticharacterDialogue
  next: {fileID: 0}
  dialogueContent:
  - character: 0
    words: Cacophonous music plays, then stops
  - character: 2
    words: Well, that was shit.
  - character: 1
    words: A little off-beat maybe.
  - character: 3
    words: Fuck you, try keeping with the beat then.
  - character: 1
    words: Maybe I could if you knew what a time signature was.
  - character: 4
    words: "Let\u2019s just calm down. Maybe take a short break. We have been recording
      for 4 hours already."
  - character: 2
    words: Who made you the boss?
  - character: 4
    words: "Nobody, I\u2019m just saying\u2026"
  - character: 2
    words: "You play bass, alright? That means you\u2019re in this band, but we do
      not grant you the title of rockstar. You don\u2019t get to decide when to break."
  - character: 3
    words: "Lay off him. If it weren\u2019t for you and Paige competing over who\u2019s
      the biggest diva, maybe we\u2019d have recorded something usable by now."
  - character: 1
    words: "Paul\u2019s right, I\u2019m done with this."
  - character: 0
    words: Paige throws her guitar out the window
  - character: 1
    words: "Can\u2019t record without a guitar, can I?"
  - character: 3
    words: "Don\u2019t need you anyway, half-witted string jockey."
  - character: 0
    words: Paige leaves and the rest of the guys turn to you.
  - character: 2
    words: So what now?
  state: 0
  setsFlag: -1
  gainsStat: -1
  isEnding: -1
